# Shared safety gate. Live commands require this exact value plus --execute.
PREDICTION_TRADER_LIVE=0

# Conservative default for a ~$100 testing bankroll. Override per command with --max-usd.
PREDICTION_TRADER_MAX_USD=5

# Local JSONL audit trail for executed trades, redemptions, and backfilled state.
# The default path is ignored by git.
PREDICTION_TRADER_LEDGER_PATH=data/trades/ledger.jsonl

# ------------------------------------------------------------------------------
# Polymarket
# ------------------------------------------------------------------------------
POLYMARKET_HOST=https://clob.polymarket.com
POLYMARKET_CHAIN_ID=137

# Private key for the Polymarket signer wallet. Keep this local; never paste it into chat.
# This is not the hardware wallet you used to fund Polymarket.
POLYMARKET_PRIVATE_KEY=0x...

# New API integrations generally use deposit wallets, signature type 3.
# Existing proxy/safe users may need 1 or 2.
POLYMARKET_SIGNATURE_TYPE=3

# Use the EVM/Polygon deposit address from Polymarket's Deposit flow.
# If Polymarket asks you to upgrade/migrate wallets, use the new deposit wallet address.
# Do not use the profile address labeled "Do not send funds to this address. For API use only."
POLYMARKET_FUNDER_ADDRESS=0x...

# Optional. If omitted, the adapter derives credentials using POLYMARKET_PRIVATE_KEY.
POLYMARKET_API_KEY=
POLYMARKET_API_SECRET=
POLYMARKET_API_PASSPHRASE=

# Polygon RPC URL for viem signer transport.
POLYGON_RPC_URL=https://polygon-bor-rpc.publicnode.com

# ------------------------------------------------------------------------------
# Vistadex
# ------------------------------------------------------------------------------
# Client API key for the Vistadex RFQ server.
# User-mode finding: this does not currently appear self-serve from the Vistadex account UI.
VISTADEX_CLIENT_API_KEY=
VISTADEX_APP_URL=https://www.app.vistadex.com
VISTADEX_RPC_URL=https://api.mainnet-beta.solana.com
VISTADEX_POSITIONS_API_URL=https://markets.vistadex.com

# Solana keypair for the Vistadex wallet. Accepted by the SDK:
# - base58 private-key export via VISTADEX_SECRET_KEY
# - base64 secret key
# - JSON array string
# - path to a keypair JSON file via VISTADEX_KEYPAIR_PATH
# Suggested generated path: wallets/vistadex-agent.keypair.json
VISTADEX_SECRET_KEY=
VISTADEX_KEYPAIR_PATH=

# ------------------------------------------------------------------------------
# WeatherEdge
# ------------------------------------------------------------------------------
# Open-Meteo is used for public forecast-model access to GFS, ECMWF, and UKMO.
OPEN_METEO_FORECAST_URL=https://api.open-meteo.com/v1/forecast
OPEN_METEO_PREVIOUS_RUNS_URL=https://previous-runs-api.open-meteo.com/v1/forecast
OPEN_METEO_GEOCODING_URL=https://geocoding-api.open-meteo.com/v1/

# NWS requires a User-Agent header. Use a project/contact string if you deploy this.
NWS_API_URL=https://api.weather.gov
NWS_USER_AGENT=prediction-trader/0.1 weatheredge

# HKO is used only for Hong Kong weather markets.
HKO_API_URL=https://data.weather.gov.hk/weatherAPI/opendata/weather.php

# NOAA NCEI CDO is used for historical/climatology pulls and requires a free token.
NOAA_CDO_API_URL=https://www.ncei.noaa.gov/cdo-web/api/v2
NOAA_CDO_TOKEN=

# Local cache for NOAA station/data JSON. Ignored by git.
WEATHER_CACHE_DIR=.cache/weatheredge

# Local durable WeatherEdge datasets. Ignored by git. The previous-run,
# observations, and resolution-actuals files are required for calibrated
# production WeatherEdge buy signals; without them live pricing skips buys
# rather than using an uncalibrated fallback.
WEATHER_OBSERVATIONS_PATH=data/weather/observations/noaa-ghcnd-daily.jsonl
WEATHER_MARKET_SNAPSHOTS_PATH=data/weather/markets/polymarket-weather-snapshots.jsonl
WEATHER_FORECAST_SNAPSHOTS_PATH=data/weather/forecasts/provider-forecasts.jsonl
WEATHER_PREVIOUS_RUN_FORECASTS_PATH=data/weather/forecasts/openmeteo-previous-runs.jsonl
WEATHER_BACKTEST_RUNS_PATH=data/weather/backtests/weatheredge-runs.jsonl
WEATHER_RESOLUTION_ACTUALS_PATH=data/weather/resolution/weather-resolution-actuals.jsonl

# GitHub Actions WeatherEdge strategy variables.
# The scheduled trader passes this to --max-model-run-age-hours and skips buys
# if GFS/ECMWF/UKMO do not share a usable recent Open-Meteo model cycle.
WEATHEREDGE_MAX_MODEL_RUN_AGE_HOURS=12
WEATHEREDGE_STRATEGY=market-informed-hybrid
WEATHEREDGE_MARKET_ANCHOR_COEFFICIENT=-0.25
WEATHEREDGE_MARKET_ANCHOR_MIN_OPPOSITE_PROBABILITY=0.50
WEATHEREDGE_HYBRID_NORMAL_MIN_MARKET_PROBABILITY=0.50
WEATHEREDGE_HYBRID_NORMAL_BUY_BUDGET_FRACTION=0.333333
WEATHEREDGE_MAX_PER_TRADE=
WEATHEREDGE_MAX_BUY_SPEND_FRACTION=0.25
WEATHEREDGE_MAX_BUY_SPEND_USD=
